# Get these from https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=ab340ef067c840fa8a96e9172a525d65
SPOTIFY_CLIENT_SECRET=8a0490cb21de4c7098d2dd37ccbeb249

# Must match the Redirect URI you set in Spotify Dashboard
REDIRECT_URI=http://127.0.0.1:4000/api/auth/spotify/callback

# Where your frontend is running
FRONTEND_URL=http://127.0.0.1:4000

# A long random string — change this!
SESSION_SECRET=waveshare-super-secret-key-2026-xK9mP2qL

# Port for the backend (default: 4000)
PORT=4000
